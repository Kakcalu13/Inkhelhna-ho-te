{
  "lines": {
    "1": [
      { "speaker": "female", "text": "I have been at this gate for four hours." },
      { "speaker": "female", "text": "Where you headed?" },
      { "speaker": "female", "text": "Detroit." },
      { "speaker": "female", "text": "On purpose?" },
      { "speaker": "female", "text": "Stop." },
      { "speaker": "female", "text": "I'm asking." },
      { "speaker": "female", "text": "My cousin's getting married. The mean one." },
      { "speaker": "female", "text": "I knew it was the mean one." },
      { "speaker": "female", "text": "How." },
      { "speaker": "female", "text": "Because the nice one already had hers and you didn't go." },
      { "speaker": "female", "text": "That is unfair and accurate." },
      { "speaker": "female", "text": "Okay, what's standby looking like." },
      { "speaker": "female", "text": "Nineteen people ahead of me." },
      { "speaker": "female", "text": "Nineteen." },
      { "speaker": "female", "text": "I counted twice because I didn't believe it the first time." },
      { "speaker": "female", "text": "You want company? I can drive over." },
      { "speaker": "female", "text": "You live forty minutes away." },
      { "speaker": "female", "text": "I have nothing going on and a car." },
      { "speaker": "female", "text": "…Yeah. Come." },
      { "speaker": "female", "text": "On my way. Don't eat the airport sushi." }
    ],
    "2": [
      { "speaker": "female", "text": "That's mine." },
      { "speaker": "female", "text": "Oh god, sorry —" },
      { "speaker": "female", "text": "It's fine, you didn't drink it." },
      { "speaker": "female", "text": "I almost did." },
      { "speaker": "female", "text": "How close are we talking." },
      { "speaker": "female", "text": "Like… my lips were on the lid." },
      { "speaker": "female", "text": "Wow." },
      { "speaker": "female", "text": "I know." },
      { "speaker": "female", "text": "Do you do this often?" },
      { "speaker": "female", "text": "Steal drinks? No. Today's a first." },
      { "speaker": "female", "text": "How's it going so far." },
      { "speaker": "female", "text": "Honestly, embarrassing." },
      { "speaker": "female", "text": "Same name?" },
      { "speaker": "female", "text": "What." },
      { "speaker": "female", "text": "On the cup. Are we both Sarah?" },
      { "speaker": "female", "text": "…Yes." },
      { "speaker": "female", "text": "Of course." },
      { "speaker": "female", "text": "This is what I get for ordering with my real name." },
      { "speaker": "female", "text": "People don't order with their real names?" },
      { "speaker": "female", "text": "I'm Pumpkin at Starbucks." },
      { "speaker": "female", "text": "That's a personality." },
      { "speaker": "female", "text": "It's a defense mechanism." },
      { "speaker": "female", "text": "Pumpkin, take your coffee. We're done here." }
    ],
    "3": [
      { "speaker": "female", "text": "I think I made a mistake." },
      { "speaker": "female", "text": "Define mistake." },
      { "speaker": "female", "text": "I texted him." },
      { "speaker": "female", "text": "Okay." },
      { "speaker": "female", "text": "…Okay?" },
      { "speaker": "female", "text": "Yeah, okay." },
      { "speaker": "female", "text": "I was waiting for you to be horrified." },
      { "speaker": "female", "text": "I'm pacing myself." },
      { "speaker": "female", "text": "I sent three." },
      { "speaker": "female", "text": "Three is fine." },
      { "speaker": "female", "text": "One had a red heart." },
      { "speaker": "female", "text": "Oh no." },
      { "speaker": "female", "text": "I know." },
      { "speaker": "female", "text": "That's the worst one." },
      { "speaker": "female", "text": "I KNOW." },
      { "speaker": "female", "text": "Have you eaten today." },
      { "speaker": "female", "text": "What does that have to do with anything." },
      { "speaker": "female", "text": "A hungry person sends red hearts. A fed person doesn't." },
      { "speaker": "female", "text": "I had toast." },
      { "speaker": "female", "text": "Toast doesn't count." },
      { "speaker": "female", "text": "Fine." },
      { "speaker": "female", "text": "Come over. I'm making pasta." }
    ],
    "4": [
      { "speaker": "female", "text": "You look exactly the same." },
      { "speaker": "female", "text": "That is either a compliment or a threat." },
      { "speaker": "female", "text": "Compliment." },
      { "speaker": "female", "text": "Pick a tone." },
      { "speaker": "female", "text": "I forgot how you talk." },
      { "speaker": "female", "text": "I forgot how you stand." },
      { "speaker": "female", "text": "How do I stand." },
      { "speaker": "female", "text": "Like you're judging architecture." },
      { "speaker": "female", "text": "…That's specific." },
      { "speaker": "female", "text": "It's accurate." },
      { "speaker": "female", "text": "Are we hugging or are we shaking hands." },
      { "speaker": "female", "text": "We are doing whatever this is." },
      { "speaker": "female", "text": "This is nothing." },
      { "speaker": "female", "text": "It's something. It's just unnamed." },
      { "speaker": "female", "text": "Mm." },
      { "speaker": "female", "text": "How long has it been." },
      { "speaker": "female", "text": "Don't ask me, you'll be embarrassed." },
      { "speaker": "female", "text": "Six years?" },
      { "speaker": "female", "text": "Eight." },
      { "speaker": "female", "text": "…Eight." },
      { "speaker": "female", "text": "Yeah." },
      { "speaker": "female", "text": "Where do we even start." }
    ],
    "5": [
      { "speaker": "female", "text": "That is too much salt." },
      { "speaker": "female", "text": "It's the right amount." },
      { "speaker": "female", "text": "It's a small chicken." },
      { "speaker": "female", "text": "It's having a big day." },
      { "speaker": "female", "text": "I'm not eating it." },
      { "speaker": "female", "text": "You will eat it and you will tell my mother it's perfect." },
      { "speaker": "female", "text": "Why your mother." },
      { "speaker": "female", "text": "Because your mother told her you'd help." },
      { "speaker": "female", "text": "I am helping." },
      { "speaker": "female", "text": "You are commenting." },
      { "speaker": "female", "text": "That's a form of helping." },
      { "speaker": "female", "text": "It is genuinely not." },
      { "speaker": "female", "text": "Hand me the lemon." },
      { "speaker": "female", "text": "You don't trust me with the lemon?" },
      { "speaker": "female", "text": "I don't trust you with anything that has a flavor." },
      { "speaker": "female", "text": "Wow." },
      { "speaker": "female", "text": "Fine, you do the lemon." },
      { "speaker": "female", "text": "I'm going to do the lemon SO well." },
      { "speaker": "female", "text": "Don't make me regret this." },
      { "speaker": "female", "text": "Too late." },
      { "speaker": "female", "text": "It's literally not too late, the lemon is on the counter." },
      { "speaker": "female", "text": "Spiritually too late." }
    ],
    "6": [
      { "speaker": "female", "text": "Pull over." },
      { "speaker": "female", "text": "We're like three minutes away." },
      { "speaker": "female", "text": "Pull over." },
      { "speaker": "female", "text": "…Okay." },
      { "speaker": "female", "text": "Sorry." },
      { "speaker": "female", "text": "Don't apologize." },
      { "speaker": "female", "text": "I just need a minute." },
      { "speaker": "female", "text": "Take ten." },
      { "speaker": "female", "text": "My mom called." },
      { "speaker": "female", "text": "Yeah." },
      { "speaker": "female", "text": "She has to do another round." },
      { "speaker": "female", "text": "…" },
      { "speaker": "female", "text": "Yeah." },
      { "speaker": "female", "text": "Okay." },
      { "speaker": "female", "text": "Don't say it's gonna be okay." },
      { "speaker": "female", "text": "I wasn't going to say it's gonna be okay." },
      { "speaker": "female", "text": "What were you gonna say." },
      { "speaker": "female", "text": "That I love you and we're gonna sit in this car as long as you need." },
      { "speaker": "female", "text": "…" },
      { "speaker": "female", "text": "Yeah." },
      { "speaker": "female", "text": "Thanks." }
    ],
    "7": [
      { "speaker": "female", "text": "Whose are these." },
      { "speaker": "female", "text": "Don't." },
      { "speaker": "female", "text": "I'm just asking." },
      { "speaker": "female", "text": "They're mine. Obviously." },
      { "speaker": "female", "text": "I didn't say —" },
      { "speaker": "female", "text": "You said it with your face." },
      { "speaker": "female", "text": "I have a neutral face." },
      { "speaker": "female", "text": "You have the most non-neutral face I have ever seen on a human." },
      { "speaker": "female", "text": "Are we fighting?" },
      { "speaker": "female", "text": "We're discussing." },
      { "speaker": "female", "text": "This is fighting." },
      { "speaker": "female", "text": "This is roommate discussion, which involves volume." },
      { "speaker": "female", "text": "Just leave them. I'll do them." },
      { "speaker": "female", "text": "No, I'll do them. I always do them." },
      { "speaker": "female", "text": "That is genuinely not true and you know it." },
      { "speaker": "female", "text": "…" },
      { "speaker": "female", "text": "Say it." },
      { "speaker": "female", "text": "It's mostly not true." },
      { "speaker": "female", "text": "Mostly?" },
      { "speaker": "female", "text": "You did them last Tuesday." },
      { "speaker": "female", "text": "Last TUESDAY." },
      { "speaker": "female", "text": "Yeah." }
    ],
    "8": [
      { "speaker": "female", "text": "I am going to die." },
      { "speaker": "female", "text": "It's a 45-minute class." },
      { "speaker": "female", "text": "I am going to die in 45 minutes." },
      { "speaker": "female", "text": "You signed up for this." },
      { "speaker": "female", "text": "I signed up because YOU said it would be fun." },
      { "speaker": "female", "text": "It IS fun." },
      { "speaker": "female", "text": "This is the opposite of fun." },
      { "speaker": "female", "text": "This is challenging." },
      { "speaker": "female", "text": "This is what the army does to people." },
      { "speaker": "female", "text": "It's barre." },
      { "speaker": "female", "text": "It's the army." },
      { "speaker": "female", "text": "We haven't started." },
      { "speaker": "female", "text": "I know we haven't started, I'm pre-suffering." },
      { "speaker": "female", "text": "Drink some water." },
      { "speaker": "female", "text": "I drank water. It made it worse." },
      { "speaker": "female", "text": "Water doesn't make things worse." },
      { "speaker": "female", "text": "You don't know that." },
      { "speaker": "female", "text": "I'm fairly sure I do." },
      { "speaker": "female", "text": "You're not a doctor." },
      { "speaker": "female", "text": "I'm not asking to be." },
      { "speaker": "female", "text": "…I love you." },
      { "speaker": "female", "text": "Stretch your hamstring." }
    ],
    "9": [
      { "speaker": "female", "text": "Don't move." },
      { "speaker": "female", "text": "I'm not moving." },
      { "speaker": "female", "text": "You just moved." },
      { "speaker": "female", "text": "I breathed." },
      { "speaker": "female", "text": "Breathe slower." },
      { "speaker": "female", "text": "Slower than this and I will pass out." },
      { "speaker": "female", "text": "Then breathe normally and I'll just be careful." },
      { "speaker": "female", "text": "That is what I was doing." },
      { "speaker": "female", "text": "…Okay." },
      { "speaker": "female", "text": "How does it look." },
      { "speaker": "female", "text": "Don't ask me yet." },
      { "speaker": "female", "text": "That is a terrifying answer." },
      { "speaker": "female", "text": "It's fine, it's just I'm not done." },
      { "speaker": "female", "text": "How NOT-done." },
      { "speaker": "female", "text": "Not even a little done." },
      { "speaker": "female", "text": "…Okay." },
      { "speaker": "female", "text": "Stop asking." },
      { "speaker": "female", "text": "I am paying you in pasta and emotional support." },
      { "speaker": "female", "text": "Then keep your head still." },
      { "speaker": "female", "text": "My head is still." },
      { "speaker": "female", "text": "Your eyebrows aren't." },
      { "speaker": "female", "text": "My EYEBROWS." }
    ],
    "10": [
      { "speaker": "female", "text": "Now." },
      { "speaker": "female", "text": "Now?" },
      { "speaker": "female", "text": "Side door." },
      { "speaker": "female", "text": "There's a side door?" },
      { "speaker": "female", "text": "There is always a side door." },
      { "speaker": "female", "text": "Do you do this a lot?" },
      { "speaker": "female", "text": "Stop talking and walk." },
      { "speaker": "female", "text": "Are we Irish-exiting?" },
      { "speaker": "female", "text": "We are exiting. The nationality is unimportant." },
      { "speaker": "female", "text": "My coat." },
      { "speaker": "female", "text": "It's by the side door." },
      { "speaker": "female", "text": "How do you know." },
      { "speaker": "female", "text": "I planted it." },
      { "speaker": "female", "text": "…You planted your coat by the side door." },
      { "speaker": "female", "text": "Earlier. When we got here." },
      { "speaker": "female", "text": "You came here pre-planning your escape." },
      { "speaker": "female", "text": "You said you wanted to leave by 9." },
      { "speaker": "female", "text": "It's 9:04." },
      { "speaker": "female", "text": "I don't run a charity." },
      { "speaker": "female", "text": "Remind me to never doubt you." },
      { "speaker": "female", "text": "Walk faster." },
      { "speaker": "female", "text": "I love you." },
      { "speaker": "female", "text": "I know." }
    ],
    "11": [
      { "speaker": "female", "text": "I can't sleep." },
      { "speaker": "female", "text": "I know." },
      { "speaker": "female", "text": "How do you know." },
      { "speaker": "female", "text": "You're texting me at midnight." },
      { "speaker": "female", "text": "Right." },
      { "speaker": "female", "text": "What if you tried sleeping." },
      { "speaker": "female", "text": "I tried that. It didn't take." },
      { "speaker": "female", "text": "You're going to be fine." },
      { "speaker": "female", "text": "What if I'm not fine." },
      { "speaker": "female", "text": "Then I'll come pick you up and we'll go get tacos." },
      { "speaker": "female", "text": "At what time." },
      { "speaker": "female", "text": "Whatever time." },
      { "speaker": "female", "text": "Even like 2pm." },
      { "speaker": "female", "text": "Even like 2pm." },
      { "speaker": "female", "text": "That is a generous offer." },
      { "speaker": "female", "text": "It's not generous, it's tacos." },
      { "speaker": "female", "text": "…What do I wear." },
      { "speaker": "female", "text": "We talked about this." },
      { "speaker": "female", "text": "I know we talked about it. I want to talk about it again." },
      { "speaker": "female", "text": "The grey thing." },
      { "speaker": "female", "text": "The grey thing." },
      { "speaker": "female", "text": "Yeah. And go to bed." }
    ]
  }
}
